              "prefilled_from_product": true
            },
            "Interest_Calculation_Period": {
              "type": "dropdown",
              "required": false,
              "prefilled_from_product": true
            },
            "Principal_Grace_Period": {
              "type": "number",
              "required": false
            },
            "Interest_Grace_Period": {
              "type": "number",
              "required": false
            }
          }
        },
        {
          "step_index": 3,
          "step_name": "Charges",
          "fields": {},
          "actions": {
            "Add_Charge": {
              "type": "button",
              "element_name": "Add Charge",
              "on_trigger": "opens Add_Charge_Form"
            }
          }
        },
        {
          "step_index": 4,
          "step_name": "Collateral",
          "fields": {
            "Collateral_Items": {
              "type": "repeating_group",
              "required": false,
              "item_fields": {
                "Collateral_Type": {
                  "type": "unspecified",
                  "required": false
                },
                "Value": {
                  "type": "number",
                  "required": false
                },
                "Description": {
                  "type": "unspecified",
                  "required": false
                }
              }
            }
          }
        }
      ]
    },
    "Add_Charge_Form": {
      "type": "form",
      "fields": {}
    },
    "Loan_Detail_Header": {
      "type": "header",
      "fields": {
        "Client_Name_Link": {
          "type": "link",
          "element_name": "Client Name",
          "on_trigger": "navigates to Client_Detail_Page"
        }
      }
    },
    "Loan_Detail_Actions": {
      "type": "state_bound_action_bar",
      "states": {
        "Submitted and Pending Approval": {
          "available_actions": [
            {
              "action_name": "Approve",
              "fields": {
                "Approved_On_Date": {
                  "type": "date",
                  "required": true
                },
                "Approved_Amount": {
                  "type": "number",
                  "required": true
                },
                "Expected_Disbursement_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "changes status to Approved"
            },
            {
              "action_name": "Reject",
              "fields": {
                "Rejection_Reason": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "marks application as Rejected"
            },
            {
              "action_name": "Withdraw",
              "fields": {
                "Withdrawal_Reason": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "marks application as Withdrawn"
            },
            {
              "action_name": "Delete",
              "preconditions": [],
              "on_success": "deletes loan application"
            }
          ]
        },
        "Approved": {
          "available_actions": [
            {
              "action_name": "Disburse",
              "fields": {
                "Disbursed_On_Date": {
                  "type": "date",
                  "required": true
                },
                "Transaction_Amount": {
                  "type": "number",
                  "required": true
                },
                "Payment_Type": {
                  "type": "dropdown",
                  "required": true,
                  "options": [
                    "Cash",
                    "Check",
                    "Mobile Money",
                    "Bank Transfer"
                  ]
                },
                "Payment_Details": {
                  "type": "unspecified",
                  "required": false
                },
                "Disburse_to_Savings": {
                  "type": "checkbox",
                  "required": false,
                  "notes": "if checked, deposits directly into client's linked savings account"
                }
              },
              "on_success": "changes status to Active and creates disbursement transaction"
            },
            {
              "action_name": "Undo Approval",
              "preconditions": [],
              "on_success": "reverts status to Submitted and Pending Approval"
            }
          ]
        },
        "Active": {
          "available_actions": [
            {
              "action_name": "Make Repayment",
              "fields": {
                "Transaction_Date": {
                  "type": "date",
                  "required": true
                },
                "Transaction_Amount": {
                  "type": "number",
                  "required": true,
                  "notes": "pre-filled with amount due",
                  "constraints": [
                    "pre_filled_with_amount_due"
                  ]
                },
                "Payment_Type": {
                  "type": "dropdown",
                  "required": true,
                  "options": [
                    "Cash",
                    "Check",
                    "Mobile Money",
                    "Bank Transfer"
                  ]
                },
                "Payment_Details": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "constraints": [
                "partial repayments are applied per configured repayment strategy"
              ],
              "on_success": "applies repayment; full settlement changes status to Closed and marks obligations met"
            },
            {
              "action_name": "Waive Interest",
              "fields": {
                "Waive_Amount": {
                  "type": "number",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "reduces interest outstanding as specified"
            },
            {
              "action_name": "Write Off",
              "fields": {
                "Write_Off_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "marks loan as Written Off"
            },
            {
              "action_name": "Close",
              "fields": {
                "Close_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "marks loan as Closed"
            },
            {
              "action_name": "Reschedule",
              "fields": {
                "Reschedule_From_Date": {
                  "type": "date",
                  "required": true
                },
                "Reason": {
                  "type": "unspecified",
                  "required": true
                },
                "Adjusted_Due_Date": {
                  "type": "date",
                  "required": false
                },
                "Grace_Fields": {
                  "type": "unspecified",
                  "required": false,
                  "notes": "grace period adjustments as applicable"
                },
                "Extra_Terms": {
                  "type": "unspecified",
                  "required": false
                },
                "New_Interest_Rate": {
                  "type": "number",
                  "required": false
                }
              },
              "on_success": "creates a pending reschedule request requiring separate approval"
            },
            {
              "action_name": "Prepay Loan",
              "fields": {
                "Prepay_Date": {
                  "type": "date",
                  "required": false
                },
                "Prepay_Amount": {
                  "type": "number",
                  "required": true
                }
              },
              "on_success": "applies prepayment per product configuration"
            },
            {
              "action_name": "Foreclosure",
              "fields": {
                "Foreclosure_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "applies foreclosure processing"
            },
            {
              "action_name": "Charge Off",
              "fields": {
                "Charge_Off_Date": {
                  "type": "date",
                  "required": false
                },
                "Note": {
                  "type": "unspecified",
                  "required": false
                }
              },
              "on_success": "marks loan as Charged Off"
            },
            {
              "action_name": "Assign Loan Officer",
              "fields": {
                "Loan_Officer": {
                  "type": "unspecified",
                  "required": true
                }
              },
              "on_success": "assigns loan officer to account"
            }
          ]
        },
        "Closed": {
          "available_actions": []
        },
        "Overpaid": {
          "available_actions": []
        },
        "Written Off": {
          "available_actions": []
        }
      }
    },
