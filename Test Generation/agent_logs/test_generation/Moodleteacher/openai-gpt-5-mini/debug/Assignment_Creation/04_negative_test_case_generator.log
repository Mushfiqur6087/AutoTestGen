  "module": "Assignment Creation",
  "category": "negative",
  "test_cases": [
    {
      "tc_id": "N-001",
      "wf_ref": null,
      "test_case": "Leave required Assignment Name blank and attempt to save",
      "preconditions": [
        "User with course editing permissions viewing a specific course with Course Edit Mode enabled and the Activity Chooser open."
      ],
      "steps": [
        "1. Ensure the Assignment Creation form is open (precondition satisfied).",
        "2. Leave the Assignment_Name field blank.",
        "3. Click the 'Save and return to course' button."
      ],
      "expected_result": "Inline validation error appears on the Assignment_Name field indicating it is required; the form does not submit; no assignment is created and the user remains on the creation form.",
      "priority": "high"
    },
    {
      "tc_id": "N-002",
      "wf_ref": null,
      "test_case": "Submit with all required fields empty",
      "preconditions": [
        "User with course editing permissions viewing a specific course with Course Edit Mode enabled and the Activity Chooser open."
      ],
      "steps": [
        "1. Ensure the Assignment Creation form is open (precondition satisfied).",
        "2. Leave all required fields empty (representative: Assignment_Name blank).",
        "3. Click the 'Save and display' button."
      ],
      "expected_result": "Inline validation error appears on the Assignment_Name field indicating it is required; the form does not submit; no assignment is created and the user remains on the creation form.",
      "priority": "high"
    },
    {
      "tc_id": "N-003",
      "wf_ref": "WF-004",
      "test_case": "Enter non-numeric value into Max Number Of Uploaded Files when File Submissions enabled",
      "preconditions": [
        "User with course editing permissions viewing a specific course with Course Edit Mode enabled and the Activity Chooser open.",
        "Submission_Types -> File_Submissions checkbox is available"
      ],
      "steps": [
        "1. Ensure the Assignment Creation form is open (precondition satisfied).",
        "2. Check the File_Submissions checkbox to reveal file-related controls.",
        "3. Enter <non-numeric value> into the Max_Number_Of_Uploaded_Files field.",
        "4. Click the 'Save and return to course' button."
      ],
      "expected_result": "Inline validation error appears on the Max_Number_Of_Uploaded_Files field indicating it must be a numeric value; the form does not submit; no assignment is created.",
      "priority": "medium"
    },
    {
      "tc_id": "N-004",
      "wf_ref": null,
      "test_case": "Enter invalid date into Due Date when Due Date enabled",
      "preconditions": [
        "User with course editing permissions viewing a specific course with Course Edit Mode enabled and the Activity Chooser open."
      ],
      "steps": [
        "1. Ensure the Assignment Creation form is open (precondition satisfied).",
        "2. In the Availability panel, check the Due_Date Enabled checkbox to enable the Due Date picker.",
        "3. Enter <invalid date format> into the Due_Date Date field.",
        "4. Click the 'Save and display' button."
      ],
      "expected_result": "Inline validation error appears on the Due_Date Date field indicating the date/time is invalid or incorrectly formatted; the form does not submit; no assignment is created.",
      "priority": "medium"
    },
    {
      "tc_id": "N-005",
      "wf_ref": null,
      "test_case": "Open Add restriction picker and submit without selecting a restriction type",
      "preconditions": [
        "User with course editing permissions viewing a specific course with Course Edit Mode enabled and the Activity Chooser open."
      ],
      "steps": [
        "1. Ensure the Assignment Creation form is open (precondition satisfied).",
        "2. Click the 'Add restriction' button to open the Restriction_Type_Picker.",
        "3. Do not select any value in the Restriction_Type_Picker (leave it blank).",
        "4. Click the 'Save and return to course' button."
      ],
      "expected_result": "Inline validation error appears on the Restriction_Type_Picker indicating a selection is required; the form does not submit; no assignment is created.",
      "priority": "medium"
    },
    {
      "tc_id": "N-006",
      "wf_ref": null,
      "test_case": "Attempt to access Assignment creation as a user without course editing permissions",
      "preconditions": [
        "User DOES NOT have course editing permissions for the target course."
      ],
      "steps": [
        "1. Log in as a user without course editing permissions.",
        "2. Navigate to the course page.",
        "3. Open the Activity Chooser.",
        "4. Attempt to select the 'Assignment' activity (or navigate directly to the assignment creation URL)."
      ],
      "expected_result": "The Assignment creation form is not displayed: the 'Assignment' option is not present in the Activity Chooser and direct navigation to the creation page is blocked; an authorization/error banner is visible indicating the user cannot add activities; no assignment creation UI is accessible.",
      "priority": "high"
    },
    {
      "tc_id": "N-007",
      "wf_ref": null,
      "test_case": "Attempt to open Assignment creation while Course Edit Mode is disabled",
      "preconditions": [
        "User has course editing permissions but Course Edit Mode is disabled on the course page."
      ],
      "steps": [
        "1. Log in as a user with course editing permissions.",
        "2. Navigate to the course page and ensure Course Edit Mode is turned OFF.",
        "3. Open the Activity Chooser.",
        "4. Attempt to select the 'Assignment' activity."
      ],
      "expected_result": "The Assignment creation form does not open: the Activity Chooser does not present the 'Assignment' option while Edit Mode is disabled (or shows a message that editing must be enabled); no assignment creation UI is accessible and no save action is possible.",
      "priority": "high"
    }
  ],
  "summary": {
    "total": 7,
    "high_priority": 4,
    "medium_priority": 3,
    "low_priority": 0
  }
}

