          "collapsible": true,
          "default_collapsed": true,
          "label": "Cars Filters",
          "fields": {
            "Car_Type": {
              "type": "unspecified",
              "label": "Car Type",
              "on_change": [
                "update_results",
                "refresh_active_filters"
              ]
            },
            "Transmission": {
              "type": "unspecified",
              "label": "Transmission",
              "on_change": [
                "update_results",
                "refresh_active_filters"
              ]
            },
            "Fuel_Policy": {
              "type": "unspecified",
              "label": "Fuel Policy",
              "on_change": [
                "update_results",
                "refresh_active_filters"
              ]
            },
            "Rental_Company": {
              "type": "unspecified",
              "label": "Rental Company",
              "on_change": [
                "update_results",
                "refresh_active_filters"
              ]
            }
          }
        }
      }
    },
    "Sorting_Controls": {
      "type": "controls",
      "description": "Sorting controls above results grid",
      "fields": {
        "Sort_By": {
          "type": "dropdown",
          "label": "Sort By",
          "options": [
            "price",
            "rating",
            "duration"
          ],
          "on_change": [
            "update_results"
          ]
        },
        "Sort_Direction": {
          "type": "toggle",
          "label": "Sort Direction",
          "options": [
            "asc",
            "desc"
          ],
          "default": "asc",
          "on_change": [
            "update_results"
          ]
        }
      }
    },
    "Active_Filters_Summary": {
      "type": "panel",
      "label": "Active Filters Summary",
      "fields": {
        "Active_Filters": {
          "type": "repeating_group",
          "label": "Active Filters",
          "item_fields": {
            "Filter_Key": {
              "type": "unspecified",
              "label": "Filter Name"
            },
            "Filter_Value": {
              "type": "unspecified",
              "label": "Filter Value"
            },
            "Remove_Filter": {
              "type": "button",
              "action_name": "Remove Filter",
              "label": "Remove",
              "on_click": [
                "remove_filter"
              ],
              "on_success": [
                "update_results",
                "refresh_active_filters"
              ]
            }
          }
        },
        "Reset_All_Filters": {
          "type": "button",
          "action_name": "Reset All Filters",
          "label": "Reset all filters",
          "preconditions": [
            "A search query has been executed and a listing results page is displayed with results loaded."
          ],
          "on_click": [
            "reset_filters"
          ],
          "on_success": [
            "update_results",
            "refresh_active_filters"
          ]
        }
      }
    }
  }
}
