      "type": "data_table",
      "preconditions": [
        "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
      ],
      "description": "Lists custom data tables that extend core entities. Provides creation form to add new custom tables and their columns.",
      "row_actions": [
        {
          "action_name": "Edit",
          "on_success": "opens Create_Data_Table_Form in edit mode for the selected custom table",
          "preconditions": [
            "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
          ]
        }
      ],
      "bulk_actions": [],
      "searchable": false,
      "create_form": {
        "type": "form",
        "fields": {
          "Data_Table_Name": {
            "type": "unspecified",
            "field_label": "Data Table Name"
          },
          "Application_Table_Name": {
            "type": "dropdown",
            "field_label": "Application Table Name",
            "options": [
              "m_client",
              "m_group",
              "m_loan",
              "m_office",
              "m_saving_account",
              "m_product_loan",
              "m_savings_product"
            ]
          },
          "Multi_Row": {
            "type": "checkbox",
            "field_label": "Multi Row"
          },
          "Columns": {
            "type": "repeating_group",
            "item_fields": {
              "Name": {
                "type": "unspecified",
                "field_label": "Column Name"
              },
              "Type": {
                "type": "dropdown",
                "field_label": "Type",
                "options": [
                  "string",
                  "number",
                  "boolean",
                  "decimal",
                  "date",
                  "datetime",
                  "text",
                  "dropdown"
                ]
              },
              "Length": {
                "type": "unspecified",
                "field_label": "Length"
              },
              "Is_Mandatory": {
                "type": "checkbox",
                "field_label": "Is Mandatory"
              },
              "Is_Unique": {
                "type": "checkbox",
                "field_label": "Is Unique"
              }
            }
          }
        },
        "submit_actions": [
          {
            "action_name": "Create",
            "on_success": "creates the custom data table and associated columns",
            "preconditions": [
              "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
            ]
          },
          {
            "action_name": "Cancel",
            "on_success": "cancels creation and returns to Manage Data Tables list"
          }
        ]
      }
    },
    "Audit_Trails": {
      "type": "data_table",
      "preconditions": [
        "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
      ],
      "description": "Displays system actions. Filters provided. Pending commands present when maker-checker enabled.",
      "searchable": true,
      "filterable_columns": [
        "Action Name",
        "Entity Name",
        "Resource ID",
        "Maker",
        "Checker",
        "Office",
        "Date Range"
      ],
      "filters": {
        "Action_Name": {
          "type": "unspecified",
          "field_label": "Action Name"
        },
        "Entity_Name": {
          "type": "unspecified",
          "field_label": "Entity Name"
        },
        "Resource_ID": {
          "type": "unspecified",
          "field_label": "Resource ID"
        },
        "Maker_ID": {
          "type": "unspecified",
          "field_label": "Maker ID"
        },
        "Checker_ID": {
          "type": "unspecified",
          "field_label": "Checker ID"
        },
        "Office": {
          "type": "unspecified",
          "field_label": "Office"
        },
        "Date_Range": {
          "type": "date",
          "field_label": "Date Range"
        }
      },
      "row_actions": [
        {
          "action_name": "View Details",
          "on_success": "opens audit entry details"
        },
        {
          "action_name": "Approve",
          "on_success": "marks the pending command as Approved and triggers post-approve processing",
          "preconditions": [
            "Processing Result == Pending",
            "maker-checker (4-eyes approval) feature flag enabled",
            "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
          ]
        },
        {
          "action_name": "Reject",
          "fields": {
            "Reason": {
              "type": "unspecified",
              "field_label": "Reason",
              "required": true
            }
          },
          "on_success": "marks the pending command as Rejected and records the rejection reason",
          "preconditions": [
            "Processing Result == Pending",
            "maker-checker (4-eyes approval) feature flag enabled",
            "Logged in as a user with administrative privileges (role permitting access to Admin/System Administration) and viewing the Admin section in the top navigation."
          ]
        }
      ]
    }
