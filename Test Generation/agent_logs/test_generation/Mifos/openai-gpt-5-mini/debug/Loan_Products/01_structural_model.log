          "action_name": "+ Create Loan Product",
          "opens": "Loan_Product_Create_Wizard",
          "preconditions": [
            "Authenticated user with permission to view and manage product configuration (access to Products/Institution sections) and at least one Fund and any referenced Charges/GL accounts preconfigured if accounting mappings will be used."
          ]
        }
      }
    },
    "Loan_Product_Create_Wizard": {
      "type": "wizard",
      "submit_actions": [
        {
          "action_name": "Save",
          "on_success": "creates or updates loan product template",
          "preconditions": [
            "Authenticated user with permission to view and manage product configuration (access to Products/Institution sections) and at least one Fund and any referenced Charges/GL accounts preconfigured if accounting mappings will be used."
          ]
        },
        {
          "action_name": "Cancel",
          "on_success": "closes wizard without saving"
        }
      ],
      "steps": [
        {
          "step_index": 1,
          "step_name": "Details",
          "fields": {
            "Product_Name": {
              "type": "unspecified",
              "required": true
            },
            "Short_Name": {
              "type": "unspecified",
              "required": true
            },
            "External_Id": {
              "type": "unspecified"
            },
            "Fund": {
              "type": "unspecified"
            },
            "Include_in_Customer_Loan_Counter": {
              "type": "checkbox"
            },
            "Start_Date": {
              "type": "date"
            },
            "Close_Date": {
              "type": "date"
            },
            "Description": {
              "type": "unspecified"
            }
          }
        },
        {
          "step_index": 2,
          "step_name": "Currency",
          "fields": {
            "Currency": {
              "type": "dropdown"
            },
            "Decimal_Places": {
              "type": "number"
            },
            "Multiples_of_Rounding": {
              "type": "number"
            },
            "Principal_Amount_Minimum": {
              "type": "number"
            },
            "Principal_Amount_Default": {
              "type": "number"
            },
            "Principal_Amount_Maximum": {
              "type": "number"
            }
          }
        },
        {
          "step_index": 3,
          "step_name": "Settings",
          "fields": {
            "Amortization_Method": {
              "type": "dropdown",
              "options": [
                "Equal Installments",
                "Equal Principal Payments"
              ]
            },
            "Interest_Method": {
              "type": "dropdown",
              "options": [
                "Flat",
                "Declining Balance"
              ]
            },
            "Interest_Calculation_Period": {
              "type": "dropdown",
              "options": [
                "Daily",
                "Same as repayment period"
              ]
            },
            "Repayment_Strategy": {
              "type": "unspecified"
            },
            "Days_in_Year": {
              "type": "dropdown",
              "options": [
                "360",
                "365",
                "Actual"
              ]
            },
            "Days_in_Month": {
              "type": "dropdown",
              "options": [
                "30",
                "Actual"
              ]
            },
            "Grace_Period": {
              "type": "number"
            },
            "Arrears_Tolerance": {
              "type": "number"
            }
          }
        },
        {
          "step_index": 4,
          "step_name": "Terms",
          "fields": {
            "Number_of_Repayments_Minimum": {
              "type": "number"
            },
            "Number_of_Repayments_Default": {
              "type": "number"
            },
            "Number_of_Repayments_Maximum": {
              "type": "number"
            },
            "Repaid_Every_Frequency_Number": {
              "type": "number"
            },
            "Repaid_Every_Frequency_Unit": {
              "type": "dropdown",
              "options": [
                "Days",
                "Weeks",
                "Months"
              ]
            },
            "Nominal_Interest_Rate_Minimum": {
              "type": "number"
            },
            "Nominal_Interest_Rate_Default": {
              "type": "number"
            },
            "Nominal_Interest_Rate_Maximum": {
              "type": "number"
            }
          }
        },
        {
          "step_index": 5,
          "step_name": "Charges",
          "fields": {
            "Charge_Search": {
              "type": "search"
            },
            "Selected_Charges": {
              "type": "repeating_group",
              "item_fields": {
                "Charge": {
                  "type": "unspecified"
                },
                "Remove_Charge": {
                  "type": "button",
                  "action_name": "Remove"
                }
              }
            }
          }
        },
        {
          "step_index": 6,
          "step_name": "Accounting",
          "fields": {
            "Accounting_Method": {
              "type": "radio",
              "options": [
                "None",
                "Cash-based",
                "Accrual (periodic)",
                "Accrual (upfront)"
              ]
            },
            "Fund_Source": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Loan_Portfolio": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Interest_On_Loans": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Income_From_Fees": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Income_From_Penalties": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Losses_Written_Off": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            },
            "Overpayment_Liability": {
              "type": "dropdown",
              "visible_when": "Accounting_Method != None"
            }
          }
        }
      ]
    },
    "Loan_Product_Detail_Actions": {
      "type": "action_bar",
      "fields": {
        "Edit": {
          "type": "button",
          "action_name": "Edit",
          "opens": "Loan_Product_Create_Wizard"
        }
      }
    }
  }
}
